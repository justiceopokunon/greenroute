{
  "name": "green-route",
  "version": "2.0.0",
  "description": "Green Route - Production-Grade Rideshare Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "echo 'Build complete'",
    "test": "node tests/test-suite.js",
    "test:production": "node tests/production-readiness.js",
    "test:e2e": "node tests/e2e-test-suite.js",
    "test:auth": "node tests/auth-test-simple.js",
    "seed": "node db.js && node seed.js",
    "deploy": "npm run test:production && npm start",
    "docker:build": "docker build -t greenroute .",
    "docker:run": "docker-compose -f config/docker-compose.yml up -d",
    "pm2:start": "pm2 start config/ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop greenroute",
    "pm2:restart": "pm2 restart greenroute",
    "pm2:logs": "pm2 logs greenroute",
    "health": "curl http://localhost:3001/api/health",
    "metrics": "curl http://localhost:3001/api/metrics",
    "backup": "cp data/greenroute.db backups/greenroute-$(date +%Y%m%d-%H%M%S).db",
    "logs": "tail -f logs/app.log",
    "production": "NODE_ENV=production npm start",
    "development": "NODE_ENV=development npm run dev",
    "start:prod": "chmod +x scripts/start-production.sh && ./scripts/start-production.sh",
    "start:dev": "chmod +x scripts/start-development.sh && ./scripts/start-development.sh"
  },
  "keywords": [
    "rideshare",
    "transport",
    "production",
    "mobile-responsive",
    "real-time",
    "gps-tracking",
    "road-routing",
    "nodejs",
    "express",
    "sqlite",
    "javascript",
    "css",
    "html",
    "api",
    "security",
    "performance"
  ],
  "author": "Green Route Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "pg": "^8.20.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "optionalDependencies": {
    "redis": "^4.6.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/greenroute/green-route.git"
  },
  "bugs": {
    "url": "https://github.com/greenroute/green-route/issues"
  },
  "homepage": "https://greenroute.com"
}
