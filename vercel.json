{
  "version": 2,
  "name": "greenroute",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/passenger", "destination": "/frontend/html/passenger.html" },
    { "source": "/driver", "destination": "/frontend/html/driver.html" },
    { "source": "/signup", "destination": "/frontend/html/signup.html" },
    { "source": "/signin", "destination": "/frontend/html/signin.html" },
    { "source": "/driver-signup", "destination": "/frontend/html/driver-signup.html" },
    { "source": "/driver-signin", "destination": "/frontend/html/driver-signin.html" },
    { "source": "/code", "destination": "/frontend/html/code.html" }
  ]
}
